{
  "name": "@rock.chen/icms-http-client",
  "private": false,
  "version": "1.0.8",
  "description": "iCMS Nextjs/Nuxtjs 路由处理，使用该包可快速创建基于iCMS的(网站/APP/小程序)",
  "type": "module",
  "main": "./dist/icms-http-client.cjs.js",
  "module": "./dist/icms-http-client.es.js",
  "browser": "./dist/icms-http-client.umd.js",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/icms-http-client.es.js",
      "require": "./dist/icms-http-client.cjs.js",
      "default": "./dist/icms-http-client.es.js"
    }
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:types": "tsc --emitDeclarationOnly --outDir dist/types",
    "test": "vitest run",
    "preview": "vite preview",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "http",
    "client",
    "request",
    "fetch",
    "api",
    "rest"
  ],
  "author": "rock.chen<szygnet@qq.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rockychen2016/icms-http-client.git"
  },
  "bugs": {
    "url": "https://github.com/rockychen2016/icms-http-client/issues"
  },
  "homepage": "https://www.icms.fun",
  "dependencies": {
    "crypto-js": "^4.2.0",
    "h3": "^1.15.4",
    "js-md5": "^0.8.3",
    "next-server-context": "^6.0.0",
    "pino": "^10.1.0"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^26.1.1",
    "pino-pretty": "^13.1.3",
    "typescript": "~5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "next-server-context": {
      "optional": true
    }
  }
}
